# Mastodon OAuth credentials for ViennaTalksBout
# Copy this file to .env and fill in your credentials.
# See scripts/register_app.py for how to obtain these values.

MASTODON_INSTANCE_URL=https://wien.rocks
MASTODON_CLIENT_ID=your_client_id_here
MASTODON_CLIENT_SECRET=your_client_secret_here
MASTODON_ACCESS_TOKEN=your_access_token_here

# Second Mastodon instance (mastodon.wien)
# Run: python scripts/register_app.py --instance https://mastodon.wien
MASTODON_2_INSTANCE_URL=https://mastodon.wien
MASTODON_2_CLIENT_ID=your_client_id_here
MASTODON_2_CLIENT_SECRET=your_client_secret_here
MASTODON_2_ACCESS_TOKEN=your_access_token_here

# Third Mastodon instance (fedi.at — Austrian Fediverse instance)
# Run: python scripts/register_app.py --instance https://fedi.at
MASTODON_3_INSTANCE_URL=https://fedi.at
MASTODON_3_CLIENT_ID=your_client_id_here
MASTODON_3_CLIENT_SECRET=your_client_secret_here
MASTODON_3_ACCESS_TOKEN=your_access_token_here

# Anthropic API credentials for topic extraction (Phase 4)
# Get your API key from https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Model to use for topic extraction (default: claude-haiku-4-5-20251001)
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Pipeline settings (all optional — defaults shown)
# VIENNATALKSBOUT_BUFFER_WINDOW_SECONDS=600
# VIENNATALKSBOUT_BUFFER_MAX_BATCH_SIZE=100
# VIENNATALKSBOUT_SNAPSHOT_DIR=data/snapshots
# VIENNATALKSBOUT_RETENTION_HOURS=24
# VIENNATALKSBOUT_STALE_STREAM_SECONDS=1800
# VIENNATALKSBOUT_HEALTH_LOG_INTERVAL=300
# VIENNATALKSBOUT_LOG_LEVEL=INFO

# RSS news datasource (all optional — disabled by default)
# Set to "true" to enable Austrian news RSS feeds alongside Mastodon
# RSS_ENABLED=false
# Comma-separated "url|name" pairs (defaults to ORF Wien, ORF News, vienna.at, OTS)
# RSS_FEEDS=https://rss.orf.at/wien.xml|orf-wien,https://rss.orf.at/news.xml|orf-news
# Seconds between poll cycles (default: 600)
# RSS_POLL_INTERVAL=600
# User-Agent header for feed requests
# RSS_USER_AGENT=ViennaTalksBout/1.0

# Bluesky datasource (all optional — disabled by default)
# Uses public search API, no authentication required
# BLUESKY_ENABLED=false
# Comma-separated search query terms (default: wien,vienna)
# BLUESKY_SEARCH_QUERIES=wien,vienna
# Language filter for search results (default: de). Set to "" for no filter.
# BLUESKY_LANG=de
# Seconds between poll cycles (default: 120)
# BLUESKY_POLL_INTERVAL=120
# Max results per query per poll (1-100, default: 25)
# BLUESKY_LIMIT=25

# Reddit datasource (all optional — disabled by default)
# Requires a Reddit "script" app: https://www.reddit.com/prefs/apps
# REDDIT_ENABLED=false
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=
# REDDIT_USERNAME=
# REDDIT_PASSWORD=
# Comma-separated subreddit names (default: wien,austria)
# REDDIT_SUBREDDITS=wien,austria
# Seconds between poll cycles (default: 60)
# REDDIT_POLL_INTERVAL=60
# Whether to include comments alongside submissions (default: true)
# REDDIT_INCLUDE_COMMENTS=true

# Wien.gv.at petitions datasource (optional — disabled by default)
# Scrapes petitionen.wien.gv.at for active citizen petitions.
# Low volume but high civic signal — each petition = verified trending concern.
# WIEN_GV_ENABLED=false
# WIEN_GV_URL=https://petitionen.wien.gv.at
# Seconds between poll cycles (default: 3600 — petitions change slowly)
# WIEN_GV_POLL_INTERVAL=3600
# WIEN_GV_USER_AGENT=ViennaTalksBout/1.0
